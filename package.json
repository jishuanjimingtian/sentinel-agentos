{
  "name": "sentinel-agentos",
  "version": "0.4.5",
  "description": "Sentinel AgentOS — 确定性 Guard 层 + 分层记忆 + 自动评估，让任何 Agent 变得可靠、可审计、可改进",
  "keywords": [
    "agent",
    "ai-agent",
    "guard",
    "safety",
    "memory",
    "evaluation",
    "sentinel",
    "agentos"
  ],
  "license": "MIT",
  "author": "Annie-Bot",
  "repository": {
    "type": "git",
    "url": "https://github.com/jishuanjimingtian/sentinel-agentos"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "sentinel-agentos": "dist/cli.js"
  },
  "files": [
    "dist/",
    "scripts/sentinel-light.js",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc && npx copyfiles -f src/dashboard.html dist/ && npx copyfiles -u 1 \"assets/**/*\" dist/assets/",
    "start": "node dist/cli.js server --port 3300",
    "dev": "tsc --watch",
    "test": "jest",
    "test:watch": "jest --watch",
    "lint": "eslint src/ --ext .ts",
    "lint:fix": "eslint src/ --ext .ts --fix",
    "format": "prettier --write \"src/**/*.ts\" \"tests/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\" \"tests/**/*.ts\"",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jest": "^29.5.0",
    "@types/node": "^20.0.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "copyfiles": "^2.4.1",
    "eslint": "^8.0.0",
    "eslint-config-prettier": "^9.0.0",
    "fluent-ffmpeg": "^2.1.3",
    "jest": "^29.0.0",
    "prettier": "^3.0.0",
    "ts-jest": "^29.0.0",
    "typescript": "^5.4.0",
    "videoshow": "^0.1.12"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "puppeteer": "^25.1.0",
    "sharp": "^0.35.1",
    "ws": "^8.21.0"
  }
}
